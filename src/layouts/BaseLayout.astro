---
// 全ページ共通のスタイルをインポート
import "../styles/style.css";

const { pageTitle, description } = Astro.props;
const profileLines = [
    "私はカドゲ，音ゲなどいろんなゲームをやってるゲーム大好きなクリエイタだ！",
    "YMMで動画作ったり，Blenderで3Dモデリングやったりもするよ！",
    "みんな，私のことはラッピーって呼んでくれ！よろしくな！",
];
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.svg">
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Kiwi+Maru:wght@300;400;500&display=swap"
            rel="stylesheet"
        />
        <meta
            name="google-site-verification"
            content="FGl0FjNZQASA2qUbweVmveRZQJr_SHfSzYgfQdE6GnA"
        />
    </head>
    <body class="kiwi-maru-light">
        <header>
            <img
                src="/img/sitelogo.png"
                alt="サイトロゴ"
                style="cursor: pointer;"
                onclick="window.location.href='/'"
            />
            <nav>
                <ul>
                    <li><label><a href="/">TOP</a></label></li>
                    <li><a href="/works">WORKS</a></li>
                    <li><a href="/about">ABOUT</a></li>
                    <li style="border-right: none;">
                        <a
                            href="https://forms.gle/2p77JCtYXe8Rsdzz5"
                            target="_blank"
                            rel="noopener">CONTACT</a
                        >
                    </li>
                </ul>
            </nav>
        </header>

        <main>
            <section id="left">
                <div id="intro">
                    <h2>管理人</h2>
                    <img
                        src="/img/ruriicon.png"
                        alt="管理人プロフィール画像"
                        style="width:90%;"
                    />
                    <div>
                        <p>
                            名前：<ruby>奏色瑠璃<rt>かないろるり</rt></ruby><br />
                            {profileLines.map((line, index) => (
                                <>
                                    {line}
                                    {index !== profileLines.length - 1 && <br />}
                                </>
                            ))}
                        </p>
                    </div>
                </div>
                <div id="twitter">
                    <h2>X</h2>
                    <a
                        class="twitter-timeline"
                        href="https://twitter.com/rappy_3899?ref_src=twsrc%5Etfw"
                        >Tweets by rappy_3899</a
                    >
                    <script
                        async
                        src="https://platform.twitter.com/widgets.js"
                        charset="utf-8"></script>
                </div>
            </section>

            <section id="main">
                <slot />
            </section>

            <section id="right">
                <div id="calendar">
                    <h2>カレンダー</h2>
                    <iframe
                        src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=Asia%2FTokyo&showPrint=0&showTitle=0&src=cnVpbi4zODk5OUBnbWFpbC5jb20&src=amEuamFwYW5lc2UjaG9saWRheUBncm91cC52LmNhbGVuZGFyLmdvb2dsZS5jb20&color=%23039be5&color=%230b8043"
                        style="border:solid 1px #777"
                        width="90%"
                        height="600"
                        frameborder="0"
                        scrolling="no"></iframe>
                </div>
                <div id="links">
                    <h2>リンク</h2>
                    <ul>
                        <li>
                            <a
                                href="https://twitter.com/ruin3899"
                                target="_blank"
                                rel="me">X</a>
                        </li>
                        <li>
                            <a
                                href="http://www.youtube.com/@rappy_3899"
                                target="_blank"
                                rel="me">YouTube</a>
                        </li>
                    </ul>
                </div>
            </section>
        </main>

        <footer>
            <p>Copyright &copy; 2025-2026 奏色瑠璃 All Rights Reserved.</p>
        </footer>
    </body>
</html>
